# Gmail IMAP settings
IMAP_SERVER=imap.gmail.com
IMAP_PORT=993

# Gmail IMAP credentials
GMAIL_USERNAME=your-email@gmail.com
GMAIL_APP_PASSWORD=your-app-password

# Directory where Paperless-ngx consumes documents
ATTACHMENT_DIR=/mnt/user/paperless/consume

# Gmail label applied to matched emails
TARGET_LABEL="(Paperless Receipts)"

# Sub-labels for categorization
LABEL_INVOICE=Invoice
LABEL_RECEIPT=Receipt

# Comma-separated keywords to match in email subjects
SUBJECT_KEYWORDS="receipt,invoice,payment,billing statement"

# Allowed attachment file extensions (comma-separated)
RECEIPT_EXTENSIONS=.pdf,.jpg,.jpeg,.png,.webp

# Docker image for HTML-to-PDF rendering
DOCKER_IMAGE=ghcr.io/puppeteer/puppeteer:latest

# Log file path
LOG_FILE=/var/log/gmail_receipt_downloader.log

# Working directory for Puppeteer temp files
PUPPETEER_WORKDIR=/mnt/user/paperless/puppeteer

# Paperless API (optional, not currently in use)
# PAPERLESS_API=http://paperless:8000/api/documents/post_document/
# PAPERLESS_TOKEN=your-token
